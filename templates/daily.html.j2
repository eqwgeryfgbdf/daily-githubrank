<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  {% include "_head.html.j2" %}
</head>
<body>
  <div class="container">
    <header class="site-header">
      <section class="hero">
        <h1>{{ article_title }}</h1>
        <p class="subtitle">今日新創建 GitHub 熱門專案精選</p>
        <div class="date-badge">{{ date_str }} · {{ timezone }}</div>
        <nav class="nav-bar">
          <a class="nav-link" href="{{ home_href }}">回首頁</a>
          <a class="nav-link" href="{{ archive_href }}">歷史文章</a>
        </nav>
      </section>
    </header>

    <main>
      <p class="description">共收錄 {{ repos | length }} 個專案。</p>

      {% if repos %}
      <div class="repo-list">
        {% for repo in repos %}
        {% set rank = loop.index %}
        {% set show_rank = true %}
        {% include "_repo-card.html.j2" %}
        {% endfor %}
      </div>
      {% else %}
      <div class="empty-state">
        <p>今日沒有符合條件的熱門專案。</p>
      </div>
      {% endif %}
    </main>

    <footer class="site-footer">
      <p><a href="{{ home_href }}">回首頁</a> · <a href="{{ archive_href }}">歷史文章</a></p>
      <p>由 <a href="https://github.com/{{ github_repo }}" target="_blank" rel="noopener noreferrer">Daily GitHub Rank</a> 自動產生</p>
    </footer>
  </div>
</body>
</html>
