LLM_PROVIDER=claude

# Claude API（若使用 Claude）
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20240620

# Ollama（若使用本機或遠端 Ollama）
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=llama3.1:8b-instruct

# GitHub 設定
GITHUB_TOKEN=
# 要推送的目標 repo，格式 owner/repo，例如 user/daily-githubrank
TARGET_REPO=
TARGET_BRANCH=main

# 生成內容設定
MAX_REPOS=5
HOMEPAGE_REPO_COUNT=5
PATH_PREFIX=daily
DATA_PREFIX=data
TIMEZONE=Asia/Taipei

# 熱門專案搜尋條件
TRENDING_DAYS=1
# TRENDING_LANGUAGE=Python
# TRENDING_TOPICS=ai,llm
MIN_STARS=0
EXCLUDE_FORKS=1
EXCLUDE_NO_DESCRIPTION=0
EXCLUDE_EMPTY_README=0

# 網站 SEO（GitHub Pages）
SITE_NAME=GitHub 每日熱門精選
SITE_DESCRIPTION=每日精選 GitHub 新創建熱門專案，由 AI 生成繁體中文介紹。
# SITE_URL=https://daily-githubrank.pages.dev
# CLOUDFLARE_PAGES_URL=https://daily-githubrank.pages.dev
# CLOUDFLARE_PAGES_PROJECT=daily-githubrank

# 提交作者資訊
COMMIT_AUTHOR_NAME=DailyTasksBot
COMMIT_AUTHOR_EMAIL=bot@example.com

# 測試用：若為 1，僅輸出檔案到容器內 /app/output
DRY_RUN=0
